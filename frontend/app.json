{
  "expo": {
    "name": "GlamBook",
    "slug": "glambook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C2185B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.glambook.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C2185B"
      },
      "package": "com.glambook.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GlamBook to access your photos."
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GlamBook to show your location on the map."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow GlamBook to save your QR code to the gallery.",
          "savePhotosPermission": "Allow GlamBook to save your QR code.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
